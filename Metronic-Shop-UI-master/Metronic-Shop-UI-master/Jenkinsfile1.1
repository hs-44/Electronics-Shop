pipeline {

    agent any

    environment {
        SONAR_PROJECT_KEY = "Electronic-shop"
        DOCKER_SERVER = "ubuntu@54.89.204.152"
        DOCKER_PATH = "/home/ubuntu/website1"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo "Getting code from GitHub"

                git(
                    url: 'https://github.com/hs-44/Electronics-Shop.git',
                    branch: 'main',
                    credentialsId: 'hs-44'
                )
            }
        }


        stage('SonarQube Analysis') {
            steps {
                echo "Running SonarQube Scan"

                withSonarQubeEnv('sonar-server') {

                    script {

                        def scannerHome = tool 'sonar-scanner'

                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                        -Dsonar.sources=.
                        """
                    }
                }
            }
        }


        stage('Copy Code To Docker Server') {

            steps {

                echo "Copying code to Docker Server"

                sshagent(['ubuntu_docker']) {

                    sh """

                    ssh -o StrictHostKeyChecking=no ${DOCKER_SERVER} '
                    
                    rm -rf ${DOCKER_PATH}
                    mkdir -p ${DOCKER_PATH}

                    '

                    scp -o StrictHostKeyChecking=no -r \
                    Metronic-Shop-UI-master/Metronic-Shop-UI-master/* \
                    ${DOCKER_SERVER}:${DOCKER_PATH}/

                    """
                }
            }
        }



        stage('Docker Build') {

            steps {

                echo "Building Docker Image"

                sshagent(['ubuntu_docker']) {

                    sh """

                    ssh -o StrictHostKeyChecking=no ${DOCKER_SERVER} '

                    cd ${DOCKER_PATH}

                    docker build -t electronic-shop:latest .

                    '

                    """
                }
            }
        }



        stage('Deploy Container') {

            steps {

                echo "Deploying Container"

                sshagent(['ubuntu_docker']) {

                    sh """

                    ssh -o StrictHostKeyChecking=no ${DOCKER_SERVER} '

                    docker stop electronic-shop || true

                    docker rm electronic-shop || true


                    docker run -d \
                    --name electronic-shop \
                    -p 80:80 \
                    electronic-shop:latest


                    '

                    """
                }
            }
        }

    }


    post {

        success {
            echo "Deployment Successful"
        }

        failure {
            echo "Deployment Failed"
        }

    }

}
