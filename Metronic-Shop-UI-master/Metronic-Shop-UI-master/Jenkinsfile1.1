pipeline {

    agent any


    environment {

        DOCKER_SERVER = "54.89.204.152"
        DOCKER_USER = "ubuntu"

        APP_DIR = "/home/ubuntu/website1"

        IMAGE_NAME = "electronic-shop:latest"

        CONTAINER_NAME = "electronic-shop"

        SSH_CREDENTIAL = "ubuntu"

    }


    stages {


        stage('Checkout Code') {

            steps {

                echo "Getting code from GitHub"


                git(
                    url: 'https://github.com/hs-44/Electronics-Shop.git',
                    branch: 'main',
                    credentialsId: 'hs-44'
                )

            }
        }



        stage('SonarQube Analysis') {


            steps {


                echo "Running SonarQube Scan"


                withSonarQubeEnv('sonar-server') {


                    script {


                        def scannerHome = tool 'sonar-scanner'


                        sh """

                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=Electronic-shop \
                        -Dsonar.sources=.

                        """

                    }

                }

            }

        }




        stage('Copy Code To Docker Server') {


            steps {


                echo "Copying code to Docker Server"


                sshagent([SSH_CREDENTIAL]) {


                    sh """

                    ssh -o StrictHostKeyChecking=no ${DOCKER_USER}@${DOCKER_SERVER} '

                    rm -rf ${APP_DIR}

                    mkdir -p ${APP_DIR}

                    '



                    scp -o StrictHostKeyChecking=no -r \
                    Metronic-Shop-UI-master/Metronic-Shop-UI-master/* \
                    ${DOCKER_USER}@${DOCKER_SERVER}:${APP_DIR}/


                    """

                }

            }

        }





        stage('Docker Build') {


            steps {


                echo "Building Docker Image"


                sshagent([SSH_CREDENTIAL]) {


                    sh """

                    ssh -o StrictHostKeyChecking=no ${DOCKER_USER}@${DOCKER_SERVER} '


                    cd ${APP_DIR}


                    docker build \
                    -t ${IMAGE_NAME} .


                    '


                    """

                }


            }

        }





        stage('Deploy Container') {


            steps {


                echo "Deploying Docker Container"


                sshagent([SSH_CREDENTIAL]) {


                    sh """

                    ssh -o StrictHostKeyChecking=no ${DOCKER_USER}@${DOCKER_SERVER} '


                    docker stop ${CONTAINER_NAME} || true


                    docker rm ${CONTAINER_NAME} || true



                    docker run -d \
                    --name ${CONTAINER_NAME} \
                    -p 80:80 \
                    ${IMAGE_NAME}



                    '


                    """

                }


            }

        }



    }



    post {


        success {


            echo "Deployment Successful"


        }


        failure {


            echo "Deployment Failed"


        }


    }


}
