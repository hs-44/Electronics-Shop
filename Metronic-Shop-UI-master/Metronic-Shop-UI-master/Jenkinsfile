pipeline {

    agent any

    tools {
        sonarQube 'sonar-scanner'
    }

    environment {

        SONAR_PROJECT_KEY = "Electronic-shop"

        DOCKER_SERVER = "ubuntu@54.89.204.152"

        DOCKER_IMAGE = "electronic-shop"

        DOCKER_CONTAINER = "electronic-shop-container"

    }


    stages {


        stage('Checkout Code') {

            steps {

                echo "Checking out code from GitHub"

                git branch: 'main',
                    url: 'https://github.com/hs-44/Electronics-Shop.git'

            }
        }



        stage('SonarQube Analysis') {

            steps {

                echo "Running SonarQube Scan"


                withSonarQubeEnv('sonar-server') {


                    sh """

                    sonar-scanner \
                    -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                    -Dsonar.sources=.

                    """

                }

            }

        }



        stage('Docker Build') {

            steps {

                echo "Building Docker image"


                sh """

                docker build \
                -t ${DOCKER_IMAGE}:latest .

                """

            }

        }



        stage('Copy Image To Docker Server') {

            steps {

                echo "Sending image to Docker server"


                sh """

                docker save \
                ${DOCKER_IMAGE}:latest \
                -o ${DOCKER_IMAGE}.tar


                scp ${DOCKER_IMAGE}.tar \
                ${DOCKER_SERVER}:/tmp/${DOCKER_IMAGE}.tar


                """

            }

        }



        stage('Deploy Container') {

            steps {

                echo "Deploying container"


                sh """

                ssh ${DOCKER_SERVER} << EOF


                docker load \
                -i /tmp/${DOCKER_IMAGE}.tar


                docker stop ${DOCKER_CONTAINER} || true


                docker rm ${DOCKER_CONTAINER} || true


                docker run -d \
                --name ${DOCKER_CONTAINER} \
                -p 80:80 \
                ${DOCKER_IMAGE}:latest


EOF

                """

            }

        }


    }


    post {


        success {

            echo "================================="
            echo "Deployment Successful"
            echo "Website: http://54.89.204.152"
            echo "================================="

        }


        failure {

            echo "Pipeline Failed - Check Console Output"

        }

    }

}
