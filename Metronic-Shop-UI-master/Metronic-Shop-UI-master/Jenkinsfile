pipeline {

    agent any


    environment {

        SONAR_PROJECT_KEY = "Electronic-shop"

        DOCKER_SERVER = "ec2-user@54.89.204.152"

        DOCKER_IMAGE = "electronic-shop"

        DOCKER_CONTAINER = "electronic-shop-container"

    }


    stages {


        stage('Checkout Code') {

            steps {

                echo "Checkout code from GitHub"

                git branch: 'main',
                    url: 'https://github.com/hs-44/Electronics-Shop.git'

            }
        }



        stage('SonarQube Analysis') {

            steps {

                echo "Running SonarQube Scanner"


                withSonarQubeEnv('sonar-server') {


                    script {

                        def scannerHome = tool 'sonar-scanner'


                        sh """

                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                        -Dsonar.sources=.

                        """

                    }

                }

            }

        }



        stage('Docker Build') {

            steps {

                echo "Building Docker image"


                sh """

                docker build \
                -t ${DOCKER_IMAGE}:latest .

                """

            }

        }



        stage('Copy Image To Docker Server') {

            steps {

                echo "Copying image to Docker server"


                sh """

                docker save ${DOCKER_IMAGE}:latest \
                -o ${DOCKER_IMAGE}.tar


                scp ${DOCKER_IMAGE}.tar \
                ${DOCKER_SERVER}:/tmp/${DOCKER_IMAGE}.tar

                """

            }

        }



        stage('Deploy Container') {

            steps {

                echo "Deploying container"


                sh """

                ssh ${DOCKER_SERVER} '

                docker load -i /tmp/${DOCKER_IMAGE}.tar


                docker stop ${DOCKER_CONTAINER} || true


                docker rm ${DOCKER_CONTAINER} || true


                docker run -d \
                --name ${DOCKER_CONTAINER} \
                -p 80:80 \
                ${DOCKER_IMAGE}:latest

                '

                """

            }

        }


    }


    post {

        success {

            echo "Deployment Successful"
            echo "URL: http://54.89.204.152"

        }


        failure {

            echo "Pipeline Failed"

        }

    }

}
